TKN_APP_SECRET=replace-with-a-long-random-secret
# Canonical URL for SEO / Open Graph (no trailing slash), e.g. https://token.fyi or your Railway URL
NEXT_PUBLIC_SITE_URL=
# Postgres (Railway often injects DATABASE_URL when DB is linked; POSTGRES_URL also works)
DATABASE_URL=
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
