# Required in production: signs session, recipient access, and workspace NDA cookies (min ~32 random bytes).
TKN_APP_SECRET=replace-with-a-long-random-secret
# Canonical URL for SEO / Open Graph (no trailing slash), e.g. https://token.fyi or your Railway URL
NEXT_PUBLIC_SITE_URL=
# Postgres — e.g. Railway Postgres (paste the URL from your host’s dashboard).
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR_DB_HOST:PORT/DATABASE_NAME
DATABASE_URL=
# Optional: Vercel Blob token (if set, used first).
# BLOB_READ_WRITE_TOKEN=
#
# Railway Bucket: add variable references from the bucket so these exist on the service:
# BUCKET, ACCESS_KEY_ID, SECRET_ACCESS_KEY, ENDPOINT, REGION (Railway preset / AWS SDK names).
# If all are set (and no blob token), vault files use the bucket.
#
# Local fallback (slug subfolders). Railway + no blob/S3 auto-uses /tmp/token-dataroom/vaults (ephemeral).
# TKN_LOCAL_VAULT_DIR=/tmp/token-vaults
# Older buckets may need: TKN_S3_FORCE_PATH_STYLE=true
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
#
# Stripe (billing — install `stripe` SDK when you add checkout/webhooks)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Client-side Elements / Checkout: use NEXT_PUBLIC_ prefix (not EXT_PUBLIC_)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# Catalog IDs (optional; defaults in src/lib/dataroom/stripe-catalog.ts)
# Plus is the only Stripe product today — Free/Unicorn are in-app tiers only.
# STRIPE_PRODUCT_PLUS_ID=prod_...
# NEXT_PUBLIC_STRIPE_PRODUCT_PLUS=prod_...   # same as above if you need it client-side
# NEXT_PUBLIC_STRIPE_PRICE_PLUS_MONTHLY=price_...   # $9.99/mo
# NEXT_PUBLIC_STRIPE_PRICE_PLUS_ANNUAL=price_...    # $96/yr
